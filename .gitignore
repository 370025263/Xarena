# ===========================================================================
# Xarena .gitignore
# Goal: ship source + vendored offline sources; NEVER ship secrets, venvs,
# build artifacts, or large/local runtime state.
# vendor/ is NOT ignored — it must ship for the offline from-scratch build.
# ===========================================================================

# --- secrets / local config (HARD: never commit) ---------------------------
*.key
.aikey
.keys.env
config.local.env
config.local.*
*secret*.local
*.secret
.env
.env.*
!.env.example

# --- python venvs / caches -------------------------------------------------
.venv*/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- build artifacts (regenerated by build.sh from vendor/) ----------------
**/_ctx/
**/offline_wheels/
*.whl
dist/
build/

# --- runtime / local state -------------------------------------------------
data/eval_runs/
data/uploads/
data/*.db
*.sqlite
*.sqlite3
run/shots/
run/*.png
*.bak

# --- agent / IDE / OS local ------------------------------------------------
.claude/
.idea/
.vscode/
node_modules/
*.log
.DS_Store
Thumbs.db
